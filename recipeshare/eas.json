{
	"cli": {
		"version": ">= 14.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"devClient": {
			"developmentClient": true,
			"distribution": "internal",
			"env": {
				"EXPO_PUBLIC_API_URL": "https://www.recipe-share.com/api",
				"EXPO_PUBLIC_NEW_RECIPE_SEED_MODE": "empty"
			}
		},
		"releaseStaging": {
			"developmentClient": false,
			"distribution": "store",
			"env": {
				"EXPO_PUBLIC_API_URL": "https://www.recipe-share.com/api",
				"EXPO_PUBLIC_NEW_RECIPE_SEED_MODE": "empty"
			}
		},
		"local": {
			"android": {
				"buildType": "apk",
				"gradleCommand": ":app:assembleRelease",
				"developmentClient": true
			},
			"env": {
				"EXPO_PUBLIC_API_URL": "https://www.recipe-share.com/api",
				"EXPO_PUBLIC_NEW_RECIPE_SEED_MODE": "empty"
			}
		},
		"production": {
			"distribution": "store",
			"autoIncrement": true,
			"env": {
				"EXPO_PUBLIC_API_URL": "https://www.recipe-share.com/api",
				"EXPO_PUBLIC_NEW_RECIPE_SEED_MODE": "empty"
			}
		}
	},
	"submit": {
		"openTesting": {
			"android": {
				"track": "beta"
			}
		},
		"production": {
			"android": {
				"track": "production"
			}
		}
	}
}
