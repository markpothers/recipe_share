{
	"name": "main",
	"version": "1.0.0",
	"main": "index.js",
	"private": true,
	"scripts": {
		"build": "./buildScripts/wslStartupScript.sh",
		"build:android": "eas build --platform android",
		"build:devClient:android": "eas build --profile devClient --platform android --clear-cache",
		"build:devClient:ios": "eas build --profile devClient --platform ios --clear-cache",
		"build:development:android": "eas build --profile development --platform android --clear-cache",
		"build:development:ios": "eas build --profile development --platform ios --clear-cache",
		"build:ios": "eas build --platform ios",
		"clean": "rm -rf node_modules ios android .expo .expo-shared package-lock.json",
		"prestart": "node ./buildScripts/startMessage.js",
		"go": "yarn install && expo start -c",
		"start": "expo start --dev-client",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"eject": "expo eject",
		"test:watch": "node ./node_modules/jest/bin/jest.js --watchAll --colors --runInBand --detectOpenHandles --coverage=false",
		"test": "node ./node_modules/jest/bin/jest.js --colors --runInBand --detectOpenHandles",
		"lint": "esw src buildScripts --color",
		"lint:watch": "yarn lint -- --w --changed ",
		"prebuild:android": "npx expo prebuild --clean",
		"prebuild:devClient:android": "npx expo prebuild --clean",
		"prebuild:development": "npx expo prebuild --clean",
		"prebuild:ios": "npx expo prebuild --clean",
		"testServer": "json-server --watch ./testServer/testData.js --routes ./testServer/routes.json --host 10.0.0.78 --middlewares ./testServer/middleware.js",
		"getipmac": "ipconfig getifaddr en0"
	},
